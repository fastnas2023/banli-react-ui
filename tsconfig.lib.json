{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "types": ["react", "react-dom"],
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "stripInternal": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/index.ts", "src/library.ts", "src/components/**/*", "src/lib/**/*"]
}
